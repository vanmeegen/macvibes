{
  "name": "macvibes",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bash scripts/preflight.sh && bun run --filter='*' dev",
    "shutdown": "bash scripts/shutdown.sh",
    "dev:web": "cd apps/web && bun run dev",
    "dev:server": "cd apps/server && bun run dev",
    "build": "bun run --filter='*' build",
    "lint": "bun run --filter='*' lint",
    "typecheck": "bun run --filter='*' typecheck",
    "test": "bun run --filter='*' test",
    "test:ci": "bun run --filter='*' test:ci",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "cd apps/server && bun run db:generate",
    "db:migrate": "cd apps/server && bun run db:migrate",
    "ci": "bun run lint && bun run typecheck && bun run test:ci",
    "start": "bun run build:web && cd apps/server && bun run start",
    "build:web": "cd apps/web && bun run build",
    "prepare": "husky",
    "baselines": "cd apps/server && bun run baselines"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/bun": "^1.1.13",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
