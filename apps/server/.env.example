# macvibes-Server — lokale Secrets. Kopieren nach `.env` (wird nicht committet).

# === Modellwahl pro Chat ======================================================
# Das Agenten-Modell wird PRO CHAT im Dropdown gewählt (Katalog: agentModel.ts);
# neue Chats starten mit Claude Sonnet 5. Der Credential-Proxy routet pro
# Request nach dem Modell im Body:
#   claude-*      -> ANTHROPIC_UPSTREAM_URL (Default https://api.anthropic.com)
#   alles andere  -> lokaler Router (LiteLLM-Shim -> Ollama)
#
# Claude-Credentials (für die claude-* Modelle). Der Token verlässt den Host
# nie und landet nie in der Sandbox-VM (die spricht nur mit dem Proxy).
# Bevorzugt: Abo-Token via `claude setup-token`:
# CLAUDE_CODE_OAUTH_TOKEN=
# Alternativ ein API-Key aus der Anthropic Console:
# ANTHROPIC_API_KEY=
#
# Lokaler Router für die Qwen-Modelle (LiteLLM-Shim). macvibes STARTET IHN
# AUTOMATISCH MIT: läuft auf der URL schon einer, wird er benutzt (nie angefasst);
# sonst wird das Startkommando gespawnt und überwacht (Health-Check + Neustart).
# Kommando: MACVIBES_LOCAL_ROUTER_CMD, sonst Auto-Detect von
# ../mac-local-coding-agent/run-anthropic-shim.sh. Shim-Log: ~/macvibes/local-router.log
# Die Shim-Config braucht den Catch-all-Eintrag "*" (sonst 400 auf Hilfsmodelle).
# MACVIBES_LOCAL_UPSTREAM_URL=http://localhost:8787
# MACVIBES_LOCAL_API_KEY=local
# MACVIBES_LOCAL_ROUTER_CMD=/pfad/zu/run-anthropic-shim.sh
#
# Zusätzliche Modell-Routen (OpenRouter-Stil, matchen VOR den Defaults) —
# so lassen sich weitere Anbieter samt eigenem Key einhängen:
# MACVIBES_MODEL_ROUTES=[{"prefix":"gpt-","upstreamUrl":"https://example.com","apiKey":"sk-..."}]
#
# SSE-Keepalive des Proxys gegen NAT-/Idle-Kappung langer Antworten lokaler
# Modelle ("Connection closed mid-response"). Default 10000 ms; 0 = aus.
# MACVIBES_PROXY_KEEPALIVE_MS=10000
#
# Turn-Timeouts: langsame (lokale) Modelle bekommen automatisch die SLOW-Werte
# (Defaults: Idle 600s / First-Event 180s / Cold-Start 300s), Claude die
# normalen (180s / 8s / 30s). Nur bei Bedarf übersteuern:
# MACVIBES_AGENT_IDLE_TIMEOUT_MS=180000
# MACVIBES_AGENT_SLOW_IDLE_TIMEOUT_MS=600000
# MACVIBES_AGENT_SLOW_FIRST_EVENT_TIMEOUT_MS=180000
# MACVIBES_AGENT_SLOW_COLD_START_TIMEOUT_MS=300000
#
# Prewarm (stiller Config-Warmup beim Projekt-Öffnen) läuft nur für schnelle
# Claude-Modelle; für langsame lokale Modelle wird er automatisch übersprungen.
# Komplett abschalten:
# MACVIBES_DISABLE_PREWARM=1

# Registrierung: jeder kann sich selbst registrieren, muss aber von einem Admin
# freigeschaltet werden. Der erste registrierte Nutzer wird automatisch Admin.
# Optional lässt sich der Admin per Username festnageln (wird beim Start
# befördert + freigeschaltet):
# MACVIBES_ADMIN_USERNAME=marco

# Sandbox-Backend: auto (Default) | microsandbox | process
# MACVIBES_SANDBOX=auto

# GitHub-Mirror des Bare-Repos (optional, Phase C). Token in der URL, bleibt
# auf dem Host. Beispiel: https://<user>:<token>@github.com/<user>/macvibes-apps.git
# MACVIBES_GITHUB_REMOTE=
# MACVIBES_MIRROR_INTERVAL_MS=600000
